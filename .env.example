# ─── TutorFlow Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=tutorflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tutorflow_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://tutorflow:change_me_in_production@db:5432/tutorflow_db

# ── Backend ──────────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_long_random_secret_key_here_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── AI (Anthropic Claude) ────────────────────────────────────────────────────
# Required for: lesson plan generation, homework generation, resource studio
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_MODEL=claude-opus-4-6
AI_MAX_TOKENS=4096

# ── Images (Unsplash) ────────────────────────────────────────────────────────
# Optional — adds topic-relevant images to lesson plans
# Free API key at: https://unsplash.com/developers (50 requests/hour free tier)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# NEXTAUTH_URL must be set to your public domain in production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_long_random_secret_here

# ── Azure deployment ──────────────────────────────────────────────────────────
# Set these when deploying to Azure
# BACKEND_CORS_ORIGINS=https://your-app.azurecontainerapps.io
# APP_BASE_URL=https://your-app.azurecontainerapps.io

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank in development to disable email (emails will be logged only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=TutorFlow
SMTP_FROM_EMAIL=noreply@tutorflow.co.uk
SMTP_USE_TLS=true
# Used for links in emails — set to your public URL in production
APP_BASE_URL=http://localhost:3000

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
