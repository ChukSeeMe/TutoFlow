# CI Dockerfile — packages a pre-built Next.js standalone output.
# The build (npm run build) runs on the GitHub Actions runner directly,
# not inside Docker, to avoid overlay-fs disk exhaustion.
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000

# Copy the standalone output (pre-built on the runner)
COPY .next/standalone ./
COPY .next/static ./.next/static
COPY public ./public

EXPOSE 3000
CMD ["node", "server.js"]
